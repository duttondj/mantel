# Copy to .env and fill in. NEVER commit .env.

# Postgres
DB_PASSWORD=change_me_to_a_long_random_string

# MinIO (S3-compatible storage)
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me_too_long_random

# Signs gallery-access cookies AND Better Auth sessions.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=replace_with_openssl_rand_hex_32

# Public URL of the app — must be reachable by the BROWSER.
# Local only:    http://localhost:13000
# LAN access:    http://<your-server-lan-ip>:13000   e.g. http://192.168.1.50:13000
APP_URL=http://localhost:13000

# --- DATABASE_URL / S3_* are assembled in docker-compose.yml ---

# --- Cloudflare Tunnel (only needed when using docker-compose.tunnel.yml) ---
# Token from Cloudflare dashboard: Zero Trust -> Networks -> Tunnels.
# When using the tunnel, also set APP_URL above to your https domain,
# e.g. APP_URL=https://mantel.yourdomain.com
CLOUDFLARE_TUNNEL_TOKEN=
