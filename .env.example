# Copy to .env and fill in. NEVER commit .env.

# Postgres
DB_PASSWORD=change_me_to_a_long_random_string

# MinIO (S3-compatible storage)
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me_too_long_random

# Signs gallery-access cookies AND Better Auth sessions.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=replace_with_openssl_rand_hex_32
BETTER_AUTH_SECRET=replace_with_openssl_rand_hex_32

# Public URL of the app — must match what the browser uses.
# With Caddy + Cloudflare: https://yourdomain.com
APP_URL=https://yourdomain.com

# Your domain name (hostname only, no https://).
# Used by Caddy for TLS cert issuance and by cloudflare-ddns to update the A record.
APP_DOMAIN=yourdomain.com

# Cloudflare API token
# Required permissions: Zone → DNS → Edit  (for DDNS A record updates)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=

# --- Storage (S3-compatible) ---
# Default: local MinIO (set up automatically by docker-compose).
# To use cloud storage instead, replace these four values:
#
#   Cloudflare R2:
#     S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#     S3_ACCESS_KEY=<R2 access key id>
#     S3_SECRET_KEY=<R2 secret access key>
#     S3_BUCKET=photos
#     S3_REGION=auto
#
#   Backblaze B2:
#     S3_ENDPOINT=https://s3.<region>.backblazeb2.com
#     S3_ACCESS_KEY=<keyID>
#     S3_SECRET_KEY=<applicationKey>
#     S3_BUCKET=your-bucket-name
#     S3_REGION=<region>   (e.g. us-west-004)
#
# When S3_ENDPOINT starts with https://, the app serves media via presigned
# URLs so photo/video bytes never flow through your server.
# Leave blank to use local MinIO (S3_* assembled in docker-compose.yml).

# Resend (transactional email — verification, password reset, expiry reminders)
RESEND_API_KEY=
RESEND_FROM=Mantel <noreply@yourdomain.com>

# Square payments (leave blank to disable the purchase button)
# SQUARE_ENVIRONMENT: 'sandbox' for testing, 'production' to take real payments
# Get credentials at: https://developer.squareup.com/apps
# SQUARE_WEBHOOK_SECRET: from Square dashboard -> Webhooks -> your subscription
# Webhook URL to register: https://<your-domain>/api/square/webhook
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SECRET=
SQUARE_ENVIRONMENT=sandbox
SQUARE_PRICE_CENTS=2000

# Days of inactivity after which uploads are automatically closed (default 14)
AUTO_CLOSE_DAYS=14
